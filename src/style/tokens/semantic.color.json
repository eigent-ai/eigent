      "bg": "bg.status-paused.subtle.default",
      "minContrast": 4.5
    },
    {
      "fg": "text.status-skipped.strong.default",
      "bg": "bg.status-skipped.subtle.default",
      "minContrast": 4.5
    },
    {
      "fg": "text.status-cancelled.strong.default",
      "bg": "bg.status-cancelled.subtle.default",
      "minContrast": 4.5
    },
    {
      "fg": "text.single-agent.strong.default",
      "bg": "bg.single-agent.subtle.default",
